generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Required Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(STUDENT)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  passwordResetTokens PasswordResetToken[]
  instructorProfile   InstructorProfile?
  bookings            Booking[]
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  token   String   @unique
  userId  String
  expires DateTime
  used    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Instructor Models ───

model InstructorProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  bio         String? @db.Text
  carType     String
  location    String
  hourlyRate  Float
  image       String?
  isActive    Boolean @default(true)

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityRules  AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  bookings           Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model AvailabilityRule {
  id            String   @id @default(cuid())
  instructorId  String
  dayOfWeek     DayOfWeek
  startHour     Int      // 0-23
  endHour       Int      // 0-23

  instructor InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, dayOfWeek, startHour])
}

model AvailabilityException {
  id            String   @id @default(cuid())
  instructorId  String
  date          DateTime @db.Date
  isBlocked     Boolean  @default(true) // true = unavailable

  instructor InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, date])
}

// ─── Booking Models ───

enum BookingStatus {
  PENDING_UPLOAD
  PENDING_VERIFICATION
  APPROVED
  CONFIRMED
  REJECTED
  CANCELLED
}

model Booking {
  id            String        @id @default(cuid())
  studentId     String
  instructorId  String
  date          DateTime      @db.Date
  startHour     Int           // 0-23
  status        BookingStatus @default(PENDING_UPLOAD)
  notes         String?       @db.Text

  student    User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  uploadedDocument   UploadedDocument?
  paymentTransaction PaymentTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instructorId, date, startHour]) // Prevent double booking
}

model UploadedDocument {
  id        String @id @default(cuid())
  bookingId String @unique
  fileName  String
  fileType  String
  fileSize  Int
  s3Key     String
  url       String

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PaymentTransaction {
  id                String  @id @default(cuid())
  bookingId         String  @unique
  stripeSessionId   String  @unique
  stripePaymentIntent String?
  amount            Float
  currency          String  @default("cad")
  status            String  @default("pending")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}